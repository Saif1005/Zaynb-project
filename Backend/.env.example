# ZAYNB Backend — copy to .env and adjust (no secrets in repo)

AWS_REGION=eu-west-3
AWS_ACCOUNT_ID=

S3_INPUT_BUCKET=
S3_OUTPUT_BUCKET=
S3_REFERENCE_BUCKET=

ORCHESTRATOR_LLM_MODEL=mistral:v0.3
OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=0
ORCHESTRATOR_TEMPERATURE=0.1
ORCHESTRATOR_NUM_CTX=4096

BIOLLM_MODEL=biogpt
PREDICTION_MODEL=microsoft/biogpt
LLM_DEVICE=cuda
LLM_MODEL_PATH=./models/biogpt-genomic-ft
SKIP_BIOGPT=false
ALLOW_RULE_BASED_FALLBACK=false
LLM_BACKEND=ollama

GATK_MARK_DUPLICATES=true
GATK_BQSR=true

PARABRICKS_IMAGE=nvcr.io/nvidia/clara/clara-parabricks:4.6.0-1
PARABRICKS_GPU_COUNT=1
PARABRICKS_MEMORY_GB=48
PARABRICKS_SHM_SIZE=8g

ORCHESTRATOR_MODE=langgraph
USE_ORCHESTRATOR=true
ORCHESTRATOR_DETERMINISTIC=true
USE_LANGGRAPH=true
MCP_TOOLS_ENABLED=true
RUN_ON_EC2=false

RUNTIME_DATA_MOUNT=/mnt/data
RUNTIME_REF_MOUNT=/mnt/data/references
RUNTIME_SCRATCH_MOUNT=/mnt/data/scratch
RUNTIME_WORK_MOUNT=/mnt/data/work

CORS_ORIGINS=http://localhost:3000
