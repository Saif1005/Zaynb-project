# Dockerfile for Agent tasks
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies (même que API pour agents)
RUN pip install --no-cache-dir \
    boto3==1.34.34 \
    botocore==1.34.34 \
    paramiko==3.4.0 \
    pysam==0.22.0 \
    pyvcf3==1.0.3 \
    biopython==1.83 \
    pandas==2.1.4 \
    numpy==1.26.3 \
    loguru==0.7.2 \
    python-dotenv==1.0.0 \
    pyyaml==6.0.1

# Copy application code
COPY src/ ./src/
COPY config/ ./config/

# Set Python path
ENV PYTHONPATH=/app

# Default command (can be overridden)
CMD ["python", "-m", "src.agents.orchestrator"]

