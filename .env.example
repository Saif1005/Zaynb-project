# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_BUCKET_NAME=genomic-cancer-pipeline
EC2_INSTANCE_TYPE=p3.2xlarge
EC2_AMI_ID=ami-xxxxxxxxxxxxx

# AWS Credentials (use AWS CLI or IAM roles instead of hardcoding)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 Paths
S3_INPUT_BUCKET=genomic-cancer-pipeline-input
S3_OUTPUT_BUCKET=genomic-cancer-pipeline-output
S3_REFERENCE_BUCKET=genomic-references
REFERENCE_GENOME_S3=s3://genomic-references/hg38/hg38.fa
KNOWN_SITES_VCF_S3=s3://genomic-references/hg38/known_sites.vcf

# Parabricks Configuration
PARABRICKS_IMAGE=nvcr.io/nvidia/clara/clara-parabricks:4.6.0-1
PARABRICKS_LICENSE_KEY=your_license_key_here
PARABRICKS_GPU_COUNT=1
PARABRICKS_MEMORY_GB=64

# LLM Configuration
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
LLM_MODEL_PATH=./models/mistral-genomic-ft
LLM_DEVICE=cuda
LLM_MAX_LENGTH=2048
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9

# Anthropic API (alternative to local LLM)
ANTHROPIC_API_KEY=sk-ant-xxxxx
USE_ANTHROPIC_API=false

# Training Configuration
TRAINING_DATA_PATH=./data/training/genomic_training_data.jsonl
TRAINING_OUTPUT_DIR=./models/checkpoints
TRAINING_EPOCHS=3
TRAINING_BATCH_SIZE=4
TRAINING_LEARNING_RATE=2e-4
TRAINING_LOGGING_STEPS=10
TRAINING_SAVE_STEPS=100

# Database Paths
CANCER_GENES_DB_PATH=./data/cancer_genes/cancer_genes_db.json
CLINVAR_DB_PATH=./data/reference/clinvar.vcf.gz
GNOMAD_DB_PATH=./data/reference/gnomad.vcf.gz
DBSNP_DB_PATH=./data/reference/dbsnp.vcf.gz

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/genomic_pipeline.log
CLOUDWATCH_LOG_GROUP=genomic-cancer-pipeline

# Pipeline Configuration
PIPELINE_WORK_DIR=./work
PIPELINE_MAX_WORKERS=4
PIPELINE_TIMEOUT_HOURS=72
PIPELINE_KEEP_INTERMEDIATE=false

# Quality Control Thresholds
MIN_COVERAGE=30
MIN_VAF=0.05
MIN_QUALITY_SCORE=20.0
MIN_MAPPING_QUALITY=20
MIN_BASE_QUALITY=20

# Reporting
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=pdf
REPORT_INCLUDE_VISUALIZATIONS=true
REPORT_INCLUDE_RECOMMENDATIONS=true
REPORT_LANGUAGE=fr
